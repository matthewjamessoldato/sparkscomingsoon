# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Verified sender — must match a domain verified in Resend
SEND_FROM=Sparks <hello@sparksesl.com>

# Resend Audience ID — create at https://resend.com/audiences
# Every waitlist signup is added as a contact. View/export/broadcast from the dashboard.
RESEND_AUDIENCE_ID=aud_xxxxxxxxxxxx

# Optional comma-separated same-owner origins allowed to invoke Server Actions
# Example: https://sparksesl.com,https://www.sparksesl.com
ALLOWED_ORIGINS=
